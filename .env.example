# AlurKarya Soft Buyer Access Password Hash (SHA-256)
# To generate a hash locally, use a SHA-256 generator or command line:
# python -c "import hashlib; print(hashlib.sha256(b'yourpassword').hexdigest())"
# Or run node:
# node -e "crypto.subtle.digest('SHA-256', new TextEncoder().encode('yourpassword')).then(b => console.log(Array.from(new Uint8Array(b)).map(x => x.toString(16).padStart(2,'0')).join('')))"

VITE_ACCESS_PASSWORD_HASH=replace_with_sha256_password_hash
